{
  "name": "retc-smart-campus",
  "version": "1.0.0",
  "description": "ระบบบริหารงานวิทยาลัยเทคนิคร้อยเอ็ด",
  "main": "app.js",
  "prisma": {
    "seed": "dotenv -e .env -- node prisma/seed.js"
  },
  "scripts": {
    "start": "node app.js",
    "dev": "nodemon app.js",
    "install:frontend": "cd frontend && npm install",
    "build:frontend": "cd frontend && npm install && npm run build",
    "deploy:migrate": "dotenv -e .env -- npx prisma migrate deploy",
    "postinstall": "npx prisma generate",
    "db:push": "dotenv -e .env -- npx prisma db push",
    "db:push:force": "dotenv -e .env -- npx prisma db push --accept-data-loss",
    "db:migrate": "dotenv -e .env -- npx prisma migrate dev",
    "db:studio": "dotenv -e .env -- npx prisma studio",
    "db:seed": "dotenv -e .env -- node prisma/seed.js",
    "db:generate": "dotenv -e .env -- npx prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^5.7.0",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-session": "^1.19.0",
    "jsonwebtoken": "^9.0.2",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-line-auth": "^0.2.9"
  },
  "devDependencies": {
    "dotenv-cli": "^11.0.0",
    "nodemon": "^3.0.2",
    "prisma": "^5.7.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
