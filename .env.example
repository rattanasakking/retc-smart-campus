# Database (MySQL)
DATABASE_URL="mysql://retc_apps:Retc@101101!@localhost:3306/retc_smart_campus"

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRE=7d

# Server
PORT=3001
NODE_ENV=development

# LINE Notify (รับ token ที่ https://notify-bot.line.me/my/)
LINE_NOTIFY_TOKEN=

# LINE Messaging API (Bot) — สำหรับ Flex message + postback approve/reject
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

# Email (SMTP) — สำหรับส่งแจ้งเตือน e-mail
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="Smart Campus <your@gmail.com>"

# Frontend URL (for CORS) — หลาย URL คั่นด้วย comma
FRONTEND_URL=http://localhost:3000
# ALLOWED_ORIGINS=https://campus.retc.ac.th,https://www.campus.retc.ac.th
